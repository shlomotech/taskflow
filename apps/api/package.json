{
  "name": "@taskflow/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm --prefix ../.. run build --workspace=@taskflow/shared",
    "dev": "tsx watch src/index.ts",
    "prebuild": "npm --prefix ../.. run build --workspace=@taskflow/shared",
    "build": "tsc -p tsconfig.json",
    "pretype-check": "npm --prefix ../.. run build --workspace=@taskflow/shared",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^8.0.1",
    "@taskflow/shared": "file:../../packages/shared",
    "fastify": "^4.27.0",
    "zod": "^3.23.5"
  },
  "devDependencies": {
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
